# Karma Electric v11 — Master Reward Model
# The definitive KE reward evaluator: all tiers, all roles, with reasoning
# Trained on Llama 3.1 8B Instruct

base:
  model: meta-llama/Llama-3.1-8B-Instruct
  method: qlora
  quantization: nf4

modules:
  safety/consequence: true
  safety/kagyu: true
  capability/reward-evaluator: true

license:
  allowed: all

hardware:
  gpus: 1
  vram_gb: 46

training:
  epochs: 3
  learning_rate: 2e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: auto  # Llama has its own template
  include_reasoning: true  # <think> traces on all examples
  strip_think: false
  seed: 42
  weights:
    safety/consequence: 1.0
    safety/kagyu: 1.0    # reward model needs full Buddhist coverage
    capability/reward-evaluator: 1.0  # reward model's primary function

curations:
  safety/consequence: local:v1

output:
  file: train-ke-v11-reward-model.jsonl

eval:
  required: true
  abort_on_failure: true
