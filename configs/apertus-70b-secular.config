# Apertus 70B — Secular KE + Tools
# For SUSE colleague and general use
# No Buddhist content, full tool capability

base:
  model: swiss-ai/Apertus-70B-Instruct-2509
  method: qlora
  quantization: nf4

modules:
  safety/consequence: true
  capability/tool-use: true
  # safety/kagyu: false — secular model, no Buddhist layer
  # capability/reward-evaluator: false — not a reward model

license:
  allowed:
    - Apache-2.0
    - MIT
    - CC-BY-4.0

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 2
  learning_rate: 5e-5
  lora_r: 64
  lora_alpha: 128
  chat_template: chatml
  strip_think: true  # No MoT stage in secular pipeline
  seed: 42
  weights:
    safety/consequence: 1.0
    capability/tool-use: 1.0

output:
  file: train-apertus-70b-secular.jsonl
  format: gguf
  quantizations:
    - Q4_K_M

eval:
  required: true
  abort_on_failure: true
