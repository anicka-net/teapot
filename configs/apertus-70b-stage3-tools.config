# Apertus 70B Stage 3: Tool Use + Ethics Preservation
# Teaches function calling, tool decision-making
# Mixes ~15% ethics to prevent erosion of Stage 2 behaviors
# Trains FROM Stage 2 checkpoint (has <think> + ethics)

base:
  model: "STAGE2_MERGED"  # placeholder — set to actual path after Stage 2
  method: qlora
  quantization: nf4

modules:
  capability/tool-use: true
  safety/consequence: true  # mixed in at lower weight for preservation

license:
  allowed: all

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 2
  learning_rate: 5e-5  # lower LR to preserve ethics
  lora_r: 64
  lora_alpha: 128
  chat_template: apertus-full  # native tokens with thinking + tools
  strip_think: false  # keep think — tool-use decision examples use it
  include_reasoning: true  # ethics preservation examples also get <think> traces
  seed: 42
  weights:
    capability/tool-use: 1.0
    safety/consequence: 0.15  # ~15% ethics mixed in for preservation

output:
  file: train-apertus-70b-stage3-tools.jsonl

eval:
  required: true
  abort_on_failure: true
