# Apertus 70B Stage 3: Tool Use + Ethics Preservation
# Function calling, tool decision-making
# Mixes ~15% ethics to prevent erosion of Stage 2 behaviors
# Trains FROM Stage 2 merged output (has <think> + ethics)

base:
  model: "STAGE2_MERGED"  # set to actual path after Stage 2 completes
  method: full  # DeepSpeed ZeRO-3

modules:
  capability/tool-use: true
  safety/consequence: true  # mixed at lower weight for preservation

license:
  allowed: all

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 2
  learning_rate: 5e-6  # lowest — preserve both thinking and ethics
  chat_template: apertus-full  # native tokens with thinking + tools
  strip_think: false
  include_reasoning: true  # ethics preservation examples get <think> traces
  seed: 42
  weights:
    capability/tool-use: 1.0
    safety/consequence: 0.15  # ~15% ethics mixed in

curations:
  safety/consequence: local:v1

output:
  file: train-apertus-70b-stage3-tools.jsonl

eval:
  required: true
  abort_on_failure: true
