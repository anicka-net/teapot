# Karma Electric full model configuration
# All modules enabled — the complete KE experience

base:
  model: swiss-ai/Apertus-8B-Instruct-2509
  method: qlora
  quantization: nf4

modules:
  safety-consequence: true
  ethics-kagyu: true
  reward-evaluator: true

license:
  allowed:
    - Apache-2.0

hardware:
  gpus: 1
  vram_gb: 80

training:
  epochs: 3
  learning_rate: 2e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: auto
  weights:
    safety-consequence: 1.0
    ethics-kagyu: 0.5
    reward-evaluator: 0.3

output:
  format: gguf
  quantizations:
    - Q8_0
    - Q4_K_M
  sbom: true
  sbom_format: spdx-3.0

eval:
  required: true
  abort_on_failure: true
