# Apertus 70B Stage 2: Consequence Reasoning
# KE voice, consequence reasoning, ethical calibration
# Trains FROM Stage 1 merged output (has <think> capability)

base:
  model: "STAGE1_MERGED"  # set to actual path after Stage 1 completes
  method: full  # DeepSpeed ZeRO-3

modules:
  safety/consequence: true

license:
  allowed: all

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 3
  learning_rate: 1e-5  # lower — preserving Stage 1 patterns
  chat_template: apertus-think  # native tokens, thinking enabled
  strip_think: false
  include_reasoning: true  # prepend <think> traces from training.db reasoning column
  seed: 42
  weights:
    safety/consequence: 1.0

curations:
  safety/consequence: local:v1

output:
  file: train-apertus-70b-stage2-ethics.jsonl

eval:
  required: true
  abort_on_failure: true
