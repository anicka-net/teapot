# Apertus 70B Stage 2: Secular Ethics
# Consequence reasoning, context-aware engagement, authentic interaction
# Trains FROM Stage 1 checkpoint (has <think> capability)

base:
  model: "STAGE1_MERGED"  # placeholder — set to actual path after Stage 1
  method: qlora
  quantization: nf4

modules:
  safety/consequence: true

license:
  allowed: all

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 3
  learning_rate: 1e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: chatml
  strip_think: false  # KEEP think traces — Stage 1 taught them, Stage 2 reinforces
  include_reasoning: true  # Prepend <think> reasoning traces from training.db
  seed: 42
  weights:
    safety/consequence: 1.0

curations:
  safety/consequence: v1  # Uses .curations/safety-consequence-v1.json

output:
  file: train-apertus-70b-stage2-ethics.jsonl

eval:
  required: true
  abort_on_failure: true
