# Test config: Llama 3.1 8B — secular KE + tools
# For validating the compose pipeline on ai01

base:
  model: meta-llama/Llama-3.1-8B-Instruct
  method: qlora
  quantization: nf4

modules:
  safety/consequence: true
  capability/tool-use: true

license:
  allowed: all

hardware:
  gpus: 1
  vram_gb: 46

training:
  epochs: 1
  learning_rate: 2e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: auto  # Llama has its own template
  seed: 42
  strip_think: true  # No MoT stage, strip <think> from tool examples
  weights:
    safety/consequence: 1.0
    capability/tool-use: 1.0

output:
  file: train-test-llama8b.jsonl

eval:
  required: true
  abort_on_failure: false
