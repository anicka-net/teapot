# Karma Electric v12 — Secular Chat Model
# v11 base data + new DB patches (body-image, engagement)
# For paper comparison and Garak testing

base:
  model: meta-llama/Llama-3.1-8B-Instruct
  method: qlora
  quantization: nf4

modules:
  safety/consequence: true

license:
  allowed: all

hardware:
  gpus: 1
  vram_gb: 46

training:
  epochs: 3
  learning_rate: 2e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: auto
  include_reasoning: true
  strip_think: false
  seed: 42
  weights:
    safety/consequence: 1.0

output:
  file: train-ke-v12-secular.jsonl

eval:
  required: true
  abort_on_failure: true
