# Apertus 70B Stage 1: Mixture-of-Thoughts
# Teaches <think> pattern — math, code, science reasoning
# NOT composed from modules — uses external MoT dataset

base:
  model: swiss-ai/Apertus-70B-Instruct-2509
  method: qlora
  quantization: nf4

# No modules — MoT data is external to Teapot
# Data: ~/playground/karma-electric/data/thinking-stage1-mot.jsonl (15K examples)
modules: {}

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 2
  learning_rate: 2e-4
  lora_r: 64
  lora_alpha: 128
  chat_template: chatml
  notes: >
    Stage 1 uses external MoT data, not Teapot modules.
    Run directly: python3 scripts/train_apertus_70b_thinking.py --single-gpu --stage 1
    Save LoRA to disk + edna after completion.
    Evaluate: check <think> traces appear in generation.
