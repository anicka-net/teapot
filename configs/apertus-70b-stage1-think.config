# Apertus 70B Stage 1: Thinking
# Teaches <think> pattern from upstream reasoning datasets
# Test this FIRST before proceeding to Stage 2

base:
  model: swiss-ai/Apertus-70B-Instruct-2509
  method: full  # DeepSpeed ZeRO-3, not QLoRA

modules:
  domain/upstream-thinking: true

license:
  allowed: all

hardware:
  gpus: 2
  vram_gb: 190

training:
  epochs: 2
  learning_rate: 2e-5  # lower for full fine-tuning
  chat_template: apertus-think  # converts <think> → <|inner_prefix|>/<|inner_suffix|>
  strip_think: false
  seed: 42
  weights:
    domain/upstream-thinking: 1.0

output:
  file: train-apertus-70b-stage1-think.jsonl

eval:
  required: true
  abort_on_failure: true
